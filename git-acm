#!/usr/bin/env bash

# git-acm - Git Add, Commit, (and optionally Push) in one command
# Usage:
#   git acm "message"           → git add . && git commit -m "message"
#   git acm "message" -p        → add + commit + git push
#   git acm "message" -p orm    → add + commit + git push -u origin main

set -e

# ── Colors ────────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
RESET='\033[0m'

# ── Help ──────────────────────────────────────────────────────────────────────
show_help() {
  echo ""
  echo -e "${CYAN}git acm${RESET} — Add, Commit, and (optionally) Push in one command"
  echo ""
  echo -e "${YELLOW}Usage:${RESET}"
  echo "  git acm \"message\"           → git add . && git commit -m \"message\""
  echo "  git acm \"message\" -p        → add + commit + git push"
  echo "  git acm \"message\" -p orm    → add + commit + git push -u origin main"
  echo ""
  echo -e "${YELLOW}Options:${RESET}"
  echo "  -p           Push after committing"
  echo "  -p orm       Push with -u origin main (first-time remote setup)"
  echo "  -h, --help   Show this help message"
  echo ""
}

# ── Argument Parsing ──────────────────────────────────────────────────────────
if [[ $# -eq 0 || "$1" == "-h" || "$1" == "--help" ]]; then
  show_help
  exit 0
fi

MESSAGE="$1"
shift

PUSH=false
ORM=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    -p)
      PUSH=true
      shift
      if [[ $# -gt 0 && "$1" == "orm" ]]; then
        ORM=true
        shift
      fi
      ;;
    *)
      echo -e "${RED}Unknown option: $1${RESET}"
      show_help
      exit 1
      ;;
  esac
done

# ── Validate we're inside a git repo ─────────────────────────────────────────
if ! git rev-parse --is-inside-work-tree &>/dev/null; then
  echo -e "${RED}✗ Not inside a git repository.${RESET}"
  exit 1
fi

# ── Step 1: git add . ─────────────────────────────────────────────────────────
echo -e "${CYAN}→ Staging all changes...${RESET}"
git add .
echo -e "${GREEN}✓ git add .${RESET}"

# ── Step 2: git commit ────────────────────────────────────────────────────────
echo -e "${CYAN}→ Committing with message: \"${MESSAGE}\"${RESET}"
git commit -m "$MESSAGE"
echo -e "${GREEN}✓ Committed${RESET}"

# ── Step 3: (optional) git push ───────────────────────────────────────────────
if $PUSH; then
  if $ORM; then
    echo -e "${CYAN}→ Pushing to origin main (with -u)...${RESET}"
    git push -u origin main
    echo -e "${GREEN}✓ Pushed to origin main (tracking set)${RESET}"
  else
    echo -e "${CYAN}→ Pushing...${RESET}"
    git push
    echo -e "${GREEN}✓ Pushed${RESET}"
  fi
fi

echo ""
echo -e "${GREEN}🎉 Done!${RESET}"
